rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email in ["doanbatri.it@gmail.com", "hoanganhdung2605@gmail.com"] && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff']);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'staff'] &&
             data.email is string &&
             data.uid == request.auth.uid;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['fullName', 'taxCode', 'customerType', 'taxCycle', 'startDate', 'nextTaxDate']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.taxCode is string && data.taxCode.size() > 0 && data.taxCode.size() < 50 &&
             data.customerType in ['individual', 'business'] &&
             data.taxCycle is string &&
             data.startDate is string &&
             data.nextTaxDate is string;
    }

    function isValidTaxRecord(data) {
      return data.keys().hasAll(['customerId', 'period', 'paymentDate']) &&
             data.customerId is string &&
             data.period is string &&
             data.paymentDate is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'staff' || isAdmin());
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidCustomer(request.resource.data);
      allow update: if isStaff() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();

      match /taxRecords/{recordId} {
        allow read: if isStaff();
        allow create: if isStaff() && isValidTaxRecord(request.resource.data);
        allow update: if isStaff() && isValidTaxRecord(request.resource.data);
        allow delete: if isAdmin();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
  }
}
